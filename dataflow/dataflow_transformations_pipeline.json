{
	"name": "dataflow_transformations_pipeline",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataflow_csv",
						"type": "DatasetReference"
					},
					"name": "DataFlowSource",
					"description": "Import data from dataset"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "dataflow_result",
						"type": "DatasetReference"
					},
					"name": "sinkDataflow"
				}
			],
			"transformations": [
				{
					"name": "RemoveColumn",
					"description": "Autogenerated by data preview actions"
				},
				{
					"name": "durationColumn"
				},
				{
					"name": "subscriptionType"
				},
				{
					"name": "durationSplit"
				},
				{
					"name": "ErrorDataFilter"
				}
			],
			"scriptLines": [
				"source(output(",
				"          user_id as integer,",
				"          user_name as string,",
				"          country as string,",
				"          subscription_type as string,",
				"          start_date as date,",
				"          end_date as date,",
				"          updated_at as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> DataFlowSource",
				"DataFlowSource select(mapColumn(",
				"          user_id,",
				"          user_name,",
				"          country,",
				"          subscription_type,",
				"          start_date,",
				"          updated_at",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RemoveColumn",
				"RemoveColumn derive({Duration (months)} = floor(monthsBetween(updated_at, start_date))) ~> durationColumn",
				"ErrorDataFilter split(subscription_type=='Free',",
				"     disjoint: false) ~> subscriptionType@(FreeUsers, paidUsers)",
				"subscriptionType@FreeUsers split({Duration (months)} >= 12,",
				"     disjoint: false,",
				"     partitionBy('hash', 1)) ~> durationSplit@(Expired, Valid)",
				"durationColumn filter({Duration (months)} >= 0) ~> ErrorDataFilter",
				"durationSplit@Expired sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDataflow"
			]
		}
	}
}